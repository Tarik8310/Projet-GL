@startuml
actor "utilisateur" as c
participant "AnomalyGUI" as anomalyv
participant "AnomalyController" as anomaly
participant "SystemGUI" as systemv

c -> anomalyv : Sélectionner capteur
c -> anomalyv : ajouter une anomalie
c -> anomalyv : Cliquer sur ajouter
anomalyv -> anomaly : Notifie l'ajout d'une anomalie

note over anomaly, systemv : Utilisation de l'introspection
anomaly -> systemv : Récupere les attributs
anomaly -> systemv : Rajoute les attributs de l'anomalie
systemv --> anomaly : Confirmation modification


@enduml
