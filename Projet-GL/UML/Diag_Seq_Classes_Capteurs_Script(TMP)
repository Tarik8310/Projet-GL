@startuml
alt Add Sensor
user -> SystemGUI : Click Add_Sensor
SystemGUI -> SensorController : Calls
SensorController -> Sensor : Instanciate
SensorController -> SensorGUI : Instanciate
else Set Sensor Unit
user -> SensorGUI : Click Set_Unit
SensorGUI -> SensorController : Calls
SensorController -> Sensor : Sets unit
SensorController -> SensorGUI : Updates
else Assign sensor
user -> SensorGUI : Click Assign
SensorGUI -> SensorController : Calls
SensorController -> System : Interrogates
alt OK
System -> SensorController : OK
SensorController -> SensorGUI : Updates
user -> SensorGUI : Pick component
SensorGUI -> SensorController : Calls
SensorController -> Sensor : Assign target
else No component
System -> SensorController : No component
SensorController -> SensorGUI : Updates
end
else Delete Sensor
user -> SensorGUI : Click delete
SensorGUI -> SensorController : Calls
SensorController -> SensorGUI : Delete Instance
SensorController -> Sensor : Delete Instance
end
@enduml
