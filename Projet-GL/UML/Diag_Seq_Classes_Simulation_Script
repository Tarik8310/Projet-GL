@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

actor "Utilisateur" as user
participant "SimulationConfigDialog" as view
participant "SimulationController" as ctrl
participant "SimulationWorker" as worker
participant "Engine" as engine
participant "SimulationPanel" as panel
participant "CSVFileOutput" as output


user -> view : Accède à "Gérer une simulation"
view --> user : Affiche les options (Lancer, Pause, Stop)


user -> view : Choisit "Lancer une simulation"

alt E1 : Paramètres invalides
    view -> view : Valider paramètres
    view --> user : Message d'erreur (Retour étape 1)
else Paramètres valides
    view -> ctrl : launch()
    ctrl -> engine : run()
    ctrl -> worker : run()0
end


loop Jusqu'à la fin du temps (sim_duration)
    engine -> engine : calculerEtat()
    engine -> worker : data_generated()
    worker -> panel : update_live_data()
    panel --> user : Affiche résultats temps réel

    alt A1 : Mettre en pause
        user -> view : Cliquer sur Pause
        view -> ctrl : pause_resume()
        ctrl -> worker : pause_sim()
        note over worker : Simulation suspendue
        
        opt Reprendre
            user -> view : Cliquer sur Reprendre
            view -> ctrl : pause_resume()
            ctrl -> worker : resume_sim()
        end
        
    else A2 : Arrêter prématurément
        user -> view : Cliquer sur Arrêter
        view -> ctrl : stop()
        ctrl -> worker : stop_sim()
        ctrl -> engine : stop()
    end
end

worker --> ctrl : simulation_finished
deactivate worker
engine --> ctrl : fin de calcul
deactivate engine

ctrl -> view : Afficher boîte de dialogue "Enregistrer ?"
view --> user : Propose l'enregistrement

alt Scénario Nominal : Enregistrer
    user -> view : Choisit "Enregistrer"
    view -> ctrl : export_csv()
    ctrl -> output : write(filepath, data)
    activate output
    output --> ctrl : confirmation
    deactivate output
    ctrl --> view : Succès
    view --> user : Notification de sauvegarde
else A3 : Ne pas enregistrer
    user -> view : Choisit "Annuler"
    view --> user : Fermeture de l'interface
end

deactivate ctrl
deactivate view

@enduml
